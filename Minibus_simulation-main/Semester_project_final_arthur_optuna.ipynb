    "    total_rejections = df_stats['reqs_rejected'].sum() if not df_stats.empty else 0\n",
    "    final_obj_cost = df_stats['obj_cost'].iloc[-1] if not df_stats.empty else 0\n",
    "    \n",
    "    # Calculate how many intervals the simulation should have run\n",
