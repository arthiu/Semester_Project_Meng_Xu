    "\n",
    "# Pivot the data for the heatmaps\n",
    "mean_pivot = stats.pivot(index=\"origin_name\", columns=\"dest_name\", values=\"mean\")\n",
    "std_pivot = stats.pivot(index=\"origin_name\", columns=\"dest_name\", values=\"std\")\n",
