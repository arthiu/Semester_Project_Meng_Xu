    "import pandas as pd\n",
    "\n",
    "# Load the custom tracker you built\n",
    "tracker_df = pd.read_csv(\"MILP_Experiments_Arthur/MASTER_EXPERIMENT_TRACKER.csv\")\n",
    "\n",
    "# Filter out the infeasible/aborted runs\n",
    "feasible_runs = tracker_df[tracker_df['Overall_Feasible'] == 'Yes']\n",
    "\n",
    "# Find the run with the highest service rate and fastest solve time\n",
    "top_performers = feasible_runs.sort_values(\n",
    "    by=['Service_Rate_%', 'Avg_Solve_Time_Secs'], \n",
    "    ascending=[False, True]\n",
    ")\n",
    "\n",
    "print(\"Top 5 configurations based on Service Rate:\")\n",
    "print(top_performers[['Experiment_Name', 'Service_Rate_%', 'Avg_Solve_Time_Secs', 'Total_Solver_Rejections']].head())"
   ]
