    "# Convert the study to a pandas dataframe\n",
    "df_study = study.trials_dataframe()\n",
    "\n",
    "df_study.to_csv(\"optuna_study_results.csv\", index=False)  # Save the study results for further analysis\n",
    "# Rename the objective columns so they make sense\n",
    "df_study.rename(columns={\n",
    "    'values_0': 'Avg_Solve_Time', \n",
    "    'values_1': 'Total_Rejections'\n",
    "}, inplace=True)\n",
    "\n",
    "# Sort by the most successful runs (e.g., fewest rejections, then fastest time)\n",
    "best_runs_df = df_study[df_study['state'] == 'COMPLETE'].sort_values(\n",
    "    by=['Total_Rejections', 'Avg_Solve_Time']\n",
    ")\n",
    "\n",
    "print(best_runs_df[['number', 'Avg_Solve_Time', 'Total_Rejections', 'params_mip_gap', 'params_heuristics', 'params_method']].head(10))\n"
   ]
