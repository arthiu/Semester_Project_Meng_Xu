    "import optuna\n",
    "\n",
    "# 1. Create the study\n",
    "# We use directions=[\"minimize\", \"minimize\"] because we want the lowest solve time AND lowest rejections.\n",
    "study = optuna.create_study(directions=[\"minimize\", \"minimize\"])\n",
    "\n",
    "# 2. Run the optimization! \n",
    "# Set n_trials to the number of hyperparameter combinations you want to test.\n",
    "print(\"Starting Optuna Hyperparameter Search...\")\n",
    "study.optimize(objective, n_trials=50)\n",
    "\n",
    "# 3. Review the results (The Pareto Front)\n",
    "# In multi-objective optimization, there isn't just one \"best\" trial. \n",
    "# There is a set of best trade-offs (e.g., fastest solve vs. fewest rejections).\n",
    "print(\"\\n=== Pareto Front (Best Trade-offs) ===\")\n",
    "pareto_front = study.best_trials\n",
    "\n",
    "for i, trial in enumerate(pareto_front):\n",
    "    print(f\"\\nOption {i+1}:\")\n",
    "    print(f\"  Solve Time: {trial.values[0]:.2f}s | Rejections: {trial.values[1]}\")\n",
    "    print(f\"  Parameters: {trial.params}\")"
