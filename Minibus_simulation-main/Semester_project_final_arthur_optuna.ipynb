    "    lat=\"lat\", \n",
    "    lon=\"lon\", \n",
    "    hover_name=\"station_name\", \n",
    "    zoom=12, \n",
    "    height=600,\n",
    "    title=\"Fribourg Area Stations\"\n",
    ")\n",
    "\n",
    "# Change the style here to avoid the 403 error\n",
    "fig.update_layout(mapbox_style=\"carto-positron\")\n",
    "fig.update_traces(marker=dict(size=10, color=\"red\"))\n",
    "fig.show()"
   ]
  },
