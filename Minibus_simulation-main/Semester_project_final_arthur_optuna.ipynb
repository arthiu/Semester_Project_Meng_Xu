    "import optuna.visualization as vis\n",
    "\n",
    "# 1. Plot the Pareto Front (Trade-off between Time and Rejections)\n",
    "# This will show you a scatter plot of your best runs.\n",
    "fig_pareto = vis.plot_pareto_front(\n",
    "    study, \n",
    "    target_names=[\"Avg Solve Time (s)\", \"Total Rejections\"]\n",
    ")\n",
    "fig_pareto.show()\n",
    "\n",
    "# 2. Plot Parameter Importances for Solve Time (Objective 0)\n",
    "fig_import_time = vis.plot_param_importances(\n",
    "    study, \n",
    "    target=lambda t: t.values[0], \n",
    "    target_name=\"Solve Time\"\n",
    ")\n",
    "fig_import_time.show()\n",
    "\n",
    "# 3. Plot Parameter Importances for Rejections (Objective 1)\n",
    "fig_import_rej = vis.plot_param_importances(\n",
    "    study, \n",
    "    target=lambda t: t.values[1], \n",
    "    target_name=\"Total Rejections\"\n",
    ")\n",
    "fig_import_rej.show()\n",
    "\n",
    "# 4. Parallel Coordinate Plot (Great for seeing which param combos lead to success)\n",
    "fig_parallel = vis.plot_parallel_coordinate(\n",
    "    study, \n",
    "    target=lambda t: t.values[0],\n",
    "    target_name=\"Solve Time\"\n",
    ")\n",
    "fig_parallel.show()"
   ]
  },
